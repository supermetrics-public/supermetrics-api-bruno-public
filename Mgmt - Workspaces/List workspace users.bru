meta {
  name: List workspace users
  type: http
  seq: 5
}

get {
  url: https://api.supermetrics.com/v1/teams/:team_id/workspaces/:workspace_uuid/users
  body: none
  auth: bearer
}

auth:bearer {
  token: {{process.env.API_KEY_TEAM_MGMT}}
}

params:path {
  team_id: {{process.env.TEAM_ID}}
  workspace_uuid: 00000000-0000-0000-0000-000000000000
}

docs {
  Gets all users in a workspace.
  Required scope: team management (elevated API key).
}
