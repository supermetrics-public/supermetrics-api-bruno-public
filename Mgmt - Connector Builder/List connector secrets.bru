meta {
  name: List connector secrets
  type: http
  seq: 6
}

get {
  url: https://api.supermetrics.com/v1/teams/{{process.env.TEAM_ID}}/connector_builder/connectors/:connector_identifier/secrets
  body: none
  auth: inherit
}

params:path {
  connector_identifier: Z3823
}

docs {
  Lists all secrets for a connector. Returns secret_placeholder and
  secret_name only — secret values are never returned.
  Referenced in connector configs as {{ secrets.<placeholder> }}.
}
