meta {
  name: Update connector secret
  type: http
  seq: 8
}

put {
  url: https://api.supermetrics.com/v1/teams/{{process.env.TEAM_ID}}/connector_builder/connectors/:connector_identifier/secrets/:secret_placeholder
  body: json
  auth: inherit
}

params:path {
  connector_identifier: Z3823
  secret_placeholder: sec_a23f23d26
}

body:json {
  {
    "secret_value": "new-secret-value-here"
  }
}

docs {
  Updates an existing secret's value. Returns 204 No Content on success.
}
