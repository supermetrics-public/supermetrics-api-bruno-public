# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored — never commit it, and never hard-code credentials into
# .bru files.

# Your Supermetrics API key. Used as the Bearer token for most requests, and as
# the `api_key` query parameter for the Data Query endpoints.
API_KEY=your-supermetrics-api-key

# A key with team-management scope. Used by the "Mgmt - Teams" and
# "Mgmt - Workspaces" requests (they override auth to use this key). If you only
# need the data/query endpoints you can leave this unset.
API_KEY_TEAM_MGMT=your-team-management-api-key

# Your Team ID. Injected into /teams/{team_id}/... paths and query params.
TEAM_ID=your-team-id

# A data source login / username, used by "Query - Transformations /
# Get fields with custom fields" (the ds_users parameter). Optional.
DS_USER=your-data-source-username

# Google BigQuery service account key, for "DWH - Destinations / Create
# destination - BQ". The API expects this as a STRING, and Bruno substitutes
# {{...}} as plain text, so store the JSON on ONE line with inner quotes
# escaped (\") and NO outer quotes.
BQ_SERVICE_ACCOUNT_KEY={\"type\":\"service_account\",\"project_id\":\"my-project\",\"private_key\":\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n\",\"client_email\":\"sa@my-project.iam.gserviceaccount.com\"}
